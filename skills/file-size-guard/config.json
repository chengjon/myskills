    "dist-lighthouse",
    "test-results",
    "test-reports",
    "playwright-report",
    ".taskmaster",
    ".omc",
    ".lighthouseci",
    ".husky",
    "screenshots",
    "archives",
    ".migration",
    "archive",
    "var",
    "scripts/dev",
    "data/grafana",
    "config/monitoring-stack",
    "coverage_html",
    "reports/database_cov",
    "reports/calculator_coverage",
    "reports/simple_calculator_full_coverage",
    "reports/data_classification_coverage",
