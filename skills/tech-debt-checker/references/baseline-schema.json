{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tech Debt Baseline",
  "description": "Approved freeze point for tech debt measurement. New baselines use metric objects so Markdown reports, gate results, and drift comparisons share the same source of truth.",
  "type": "object",
  "required": [
    "metric_version",
    "generated_at",
    "generated_by",
    "project",
    "mode",
    "git",
    "metrics",
    "gate_defaults"
  ],
  "additionalProperties": true,
  "properties": {
    "metric_version": {
      "type": "string",
      "description": "Schema version. Use v2.x for metric-object baselines.",
      "pattern": "^v\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of baseline generation"
    },
    "generated_by": {
      "type": "string",
      "description": "Tool, skill, script, or agent that generated this baseline"
    },
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "mode": {
      "type": "string",
      "enum": ["init-baseline", "baseline-migration"],
      "description": "Baselines are only written from explicit baseline modes"
    },
    "git": {
      "type": "object",
      "required": ["sha", "dirty_worktree"],
      "additionalProperties": true,
      "properties": {
        "sha": {
          "type": "string",
          "description": "Commit measured for this baseline"
        },
        "branch": {
          "type": "string"
        },
        "dirty_worktree": {
          "type": "boolean",
          "description": "Whether uncommitted changes were present during measurement"
        },
        "dirty_summary": {
          "type": "string"
        }
      }
    },
    "tool_versions": {
      "type": "object",
      "description": "Versions of relevant measurement tools such as node, npm, tsc, eslint, pytest, ruff, cargo"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/metric"
      }
    },
    "gate_defaults": {
      "type": "object",
      "required": ["hard", "soft"],
      "additionalProperties": false,
      "properties": {
        "hard": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Metric IDs or glob-like metric patterns hard-gated by default"
        },
        "soft": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Metric IDs or patterns observed for warning/drift"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "legacy_metrics": {
      "type": "object",
      "description": "Optional read-only carryover from pre-v2 flat baselines. Do not write new metrics here."
    }
  },
  "definitions": {
    "metric": {
      "type": "object",
      "required": [
        "id",
        "dimension",
        "scope",
        "kind",
        "value",
        "unit",
        "tool",
        "command_id",
        "source_roots",
        "excludes",
        "measured_at",
        "git_sha",
        "dirty_worktree",
        "gate",
        "status"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_\\.:-]*$",
          "description": "Stable metric key, scoped when needed, e.g. backend_type_errors"
        },
        "dimension": {
          "type": "string",
          "enum": ["D1", "D2", "D3", "D4", "D5", "D6"]
        },
        "scope": {
          "type": "string",
          "description": "Measured area such as backend, frontend, repo, package name, or path group"
        },
        "kind": {
          "type": "string",
          "enum": ["Measured", "Inferred", "Historical Baseline"]
        },
        "value": {
          "description": "Measured value",
          "oneOf": [
            { "type": "number" },
            { "type": "integer" },
            { "type": "boolean" },
            { "type": "string" },
            { "type": "array" },
            { "type": "object" },
            { "type": "null" }
          ]
        },
        "unit": {
          "type": "string",
          "examples": ["count", "percent", "status", "files", "bytes"]
        },
        "tool": {
          "type": "string"
        },
        "command_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_:-]*$"
        },
        "source_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excludes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "line_count_method": {
          "type": "string",
          "description": "Required for file length metrics"
        },
        "measured_at": {
          "type": "string",
          "format": "date-time"
        },
        "git_sha": {
          "type": "string"
        },
        "dirty_worktree": {
          "type": "boolean"
        },
        "gate": {
          "type": "string",
          "enum": ["hard", "soft", "none"]
        },
        "target": {
          "description": "Desired threshold for gated metrics"
        },
        "baseline_value": {
          "description": "Approved baseline value when comparing drift"
        },
        "drift": {
          "description": "Numeric or structured delta from baseline"
        },
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "unavailable", "not_applicable"]
        },
        "reason": {
          "type": "string",
          "description": "Required when status is unavailable or not_applicable"
        }
      }
    }
  }
}
